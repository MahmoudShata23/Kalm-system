  "components": {
    "schemas": {
      "BranchAccessResponse": {
        "required": [
          "scope",
          "branchIds",
          "operationalBranchIds"
        ],
        "type": "object",
        "properties": {
          "scope": {
            "type": "string"
          },
          "branchIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "operationalBranchIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          }
        }
      },
      "CsrfTokenResponse": {
        "required": [
          "requestToken"
        ],
        "type": "object",
        "properties": {
          "requestToken": {
            "type": "string"
          }
        }
      },
      "CurrentUserResponse": {
        "required": [
          "isAuthenticated",
          "username",
          "displayName",
          "preferredLanguage",
          "inactivityExpiresAtUtc",
          "absoluteExpiresAtUtc",
          "reauthenticationValidUntilUtc",
          "permissions",
          "branchAccess"
        ],
        "type": "object",
        "properties": {
          "isAuthenticated": {
            "type": "boolean"
          },
          "username": {
            "type": [
              "null",
              "string"
            ]
          },
          "displayName": {
            "type": [
              "null",
              "string"
            ]
          },
          "preferredLanguage": {
            "type": [
              "null",
              "string"
            ]
          },
          "inactivityExpiresAtUtc": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "absoluteExpiresAtUtc": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "reauthenticationValidUntilUtc": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "branchAccess": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/BranchAccessResponse"
              }
            ]
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "PermissionCatalogueResponse": {
        "required": [
          "catalogueVersion",
          "permissions"
        ],
        "type": "object",
        "properties": {
          "catalogueVersion": {
            "type": "string"
          },
          "permissions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PermissionPresentationResponse"
            }
          }
        }
      },
      "PermissionPresentationResponse": {
        "required": [
          "code",
          "groupCode",
          "groupOrder",
          "itemOrder",
          "englishLabel",
          "englishDescription",
          "arabicLabel",
          "arabicDescription"
        ],
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "groupCode": {
            "type": "string"
          },
          "groupOrder": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "itemOrder": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "englishLabel": {
            "type": "string"
          },
          "englishDescription": {
            "type": "string"
          },
          "arabicLabel": {
            "type": "string"
          },
          "arabicDescription": {
            "type": "string"
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "RoleDetailResponse": {
        "required": [
          "id",
          "name",
          "status",
          "isProtectedSystemRole",
          "activeAssignmentCount",
          "permissionCodes",
          "createdAtUtc",
          "updatedAtUtc",
          "archivedAtUtc"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "isProtectedSystemRole": {
            "type": "boolean"
          },
          "activeAssignmentCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "permissionCodes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdAtUtc": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAtUtc": {
            "type": "string",
            "format": "date-time"
          },
          "archivedAtUtc": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          }
        }
      },
      "RoleListResponse": {
        "required": [
          "items",
          "page",
          "pageSize",
          "totalCount"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RoleSummaryResponse"
            }
          },
          "page": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "pageSize": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "totalCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "RoleSummaryResponse": {
        "required": [
          "id",
          "name",
          "status",
          "isProtectedSystemRole",
          "permissionCount",
          "activeAssignmentCount",
          "updatedAtUtc"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "isProtectedSystemRole": {
            "type": "boolean"
