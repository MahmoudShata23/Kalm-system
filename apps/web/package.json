{
  "name": "@kalm/web",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": "24.18.0",
    "npm": "11.16.0"
  },
  "scripts": {
    "start": "ng serve --host 127.0.0.1 --port 4200",
    "start:e2e": "ng serve --configuration e2e --host 127.0.0.1 --port 4200",
    "start:e2e:production": "ng serve --configuration production --host 127.0.0.1 --port 4201",
    "build": "ng build --configuration production",
    "lint": "eslint .",
    "test": "vitest run",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@angular/animations": "22.0.7",
    "@angular/common": "22.0.7",
    "@angular/compiler": "22.0.7",
    "@angular/core": "22.0.7",
    "@angular/forms": "22.0.7",
    "@primeuix/themes": "3.0.0",
    "@angular/platform-browser": "22.0.7",
    "@angular/router": "22.0.7",
    "primeicons": "8.0.0",
    "primeng": "22.0.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "22.0.7",
    "@angular/cli": "22.0.7",
    "@angular/compiler-cli": "22.0.7",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "angular-eslint": "22.1.0",
    "eslint": "10.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
