{
  "AllowedHosts": "*",
  "Database": {
    "ConnectionString": ""
  },
  "PasswordHashing": {
    "Iterations": 220000
  },
  "ManagementAuthentication": {
    "InactivityMinutes": 20,
    "AbsoluteLifetimeHours": 8,
    "ReauthenticationMinutes": 5,
    "FailureThreshold": 5,
    "FailureWindowMinutes": 15,
    "LockoutMinutes": 15,
    "LoginRequestsPerMinute": 10
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
